---
interface Point {
  age: number;
  label: string;
  count: number;
}

interface Props {
  title: string;
  points: Point[];
}

const { title, points } = Astro.props;
const labels = [...new Set(points.map((point) => point.label))];
const ages = [...new Set(points.map((point) => point.age))].sort((a, b) => a - b);
const maxCount = Math.max(...points.map((point) => point.count));
const width = 660;
const height = 260;
const paddingX = 46;
const paddingY = 24;
const palette = ["#1a3a5c", "#6b7a8c", "#94a3b8", "#4b5563"];

const series = labels.map((label, index) => {
  const values = ages.map((age) => {
    const point = points.find((entry) => entry.label === label && entry.age === age);
    return point?.count ?? 0;
  });

  const polyline = values
    .map((value, pointIndex) => {
      const x =
        paddingX +
        (pointIndex / Math.max(1, ages.length - 1)) * (width - paddingX * 2);
      const y =
        height -
        paddingY -
        (value / Math.max(1, maxCount)) * (height - paddingY * 2);
      return `${x},${y}`;
    })
    .join(" ");

  return {
    label,
    color: palette[index % palette.length],
    values,
    polyline,
  };
});
---

<article class="chart-card">
  <div class="chart-head">
    <h3>{title}</h3>
    <div class="legend">
      {series.map((item) => (
        <span class="legend-item">
          <i style={`background:${item.color}`}></i>
          {item.label}
        </span>
      ))}
    </div>
  </div>
  <svg viewBox={`0 0 ${width} ${height}`} class="line-chart" aria-label={title}>
    <line x1={paddingX} y1={height - paddingY} x2={width - paddingX} y2={height - paddingY} class="axis" />
    <line x1={paddingX} y1={paddingY} x2={paddingX} y2={height - paddingY} class="axis" />

    {ages.map((age, index) => {
      const x =
        paddingX + (index / Math.max(1, ages.length - 1)) * (width - paddingX * 2);
      return (
        <>
          <line x1={x} y1={paddingY} x2={x} y2={height - paddingY} class="grid-line" />
          <text x={x} y={height - 6} text-anchor="middle" class="axis-label">{age}</text>
        </>
      );
    })}

    {Array.from({ length: 4 }).map((_, index) => {
      const ratio = index / 3;
      const value = Math.round(maxCount * (1 - ratio));
      const y = paddingY + ratio * (height - paddingY * 2);
      return (
        <>
          <line x1={paddingX} y1={y} x2={width - paddingX} y2={y} class="grid-line" />
          <text x={paddingX - 10} y={y + 4} text-anchor="end" class="axis-label">{value.toLocaleString("en-US")}</text>
        </>
      );
    })}

    {series.map((item) => (
      <>
        <polyline points={item.polyline} fill="none" stroke={item.color} stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
        {item.values.map((value, index) => {
          const x =
            paddingX +
            (index / Math.max(1, ages.length - 1)) * (width - paddingX * 2);
          const y =
            height -
            paddingY -
            (value / Math.max(1, maxCount)) * (height - paddingY * 2);
          return <circle cx={x} cy={y} r="4" fill={item.color}></circle>;
        })}
      </>
    ))}
  </svg>
</article>
