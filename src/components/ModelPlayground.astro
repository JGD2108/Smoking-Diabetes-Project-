function labelForSmoking(value) {
  return smokingContextLabels[value] ?? String(value);
}

function labelForDrinking(value) {
  return drinkingLabels[value] ?? String(value);
}

function topProbability(result) {
  return result.probabilities?.[0]?.prob ?? 0;
}

function keyMeasures(values) {
  return `Waistline ${values.waistline} cm; BLDS ${values.BLDS} mg/dL; triglyceride ${values.triglyceride} mg/dL; gamma-GTP ${values.gamma_GTP} U/L.`;
}

function contextSummary(values) {
  return `Context: ${labelForDrinking(values.DRK_YN)}; ${labelForSmoking(values.SMK_stat_type_cd)}.`;
}

const staticPopulationRows = samplePopulation
  .map((person) => ({
    person,
    prediction: staticPopulationPredictions[person.id],
  }))
  .filter((row) => row.prediction);
---

<section class="explorer-block">
  <div class="subsection-block">
    <h3>7.1 Representative health profiles</h3>
    <p>
      To illustrate model behavior in a controlled manner, five representative health profiles are
      evaluated below. Each row summarizes a clinically interpretable profile together with the
      corresponding probabilistic outputs from the smoking and drinking classifiers.
    </p>

    {!isStaticDeployment && (
      <button type="button" class="text-button" id="run-population-button">
        Evaluate representative profiles
      </button>
    )}

    {!isStaticDeployment && (
      <div id="population-status" class="form-status" aria-live="polite"></div>
    )}

    <div id="population-results-shell">
      <table class="academic-table prediction-table">
        <caption>Table 4. Model prediction results for representative health profiles</caption>
        <thead>
          <tr>
            <th>Profile</th>
            <th>Clinical description</th>
            <th>Key indicators and known context</th>
            <th>Smoking estimate</th>
            <th>Drinking estimate</th>
          </tr>
        </thead>
        <tbody id="population-results-body">
          {staticPopulationRows.map(({ person, prediction }) => (
            <tr>
              <td class="prediction-profile">{person.name}</td>
              <td>{person.blurb}</td>
              <td>
                <div class="prediction-stack prediction-measures">
                  <span>{keyMeasures(person.values)}</span>
                  <span>{contextSummary(person.values)}</span>
                </div>
              </td>
              <td>
                <div class="prediction-stack prediction-estimate">
                  <strong>{labelForSmoking(prediction.smoking.label)}</strong>
                  <span>{(topProbability(prediction.smoking) * 100).toFixed(1)}% probability</span>
                </div>
              </td>
              <td>
                <div class="prediction-stack prediction-estimate">
                  <strong>{labelForDrinking(prediction.drinking.label)}</strong>
                  <span>{(topProbability(prediction.drinking) * 100).toFixed(1)}% probability</span>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <p class="table-note">
      <strong>Note.</strong> Predictions shown are probabilistic estimates derived from
      population-level patterns. They do not constitute medical diagnosis or clinical advice.
    </p>
  </div>

  <div class="subsection-block">
    <h3>7.2 Interactive individual estimation</h3>
    <p>
      A server-backed estimation form is provided below for case-by-case exploration. The form
      preserves the same variable structure used in the deployed models so that the estimated class
      probabilities remain consistent with the analytical workflow documented in this report.
    </p>

    {isStaticDeployment ? (
      <div class="paper-note">
        The GitHub Pages deployment is static and therefore presents only the representative-profile
        table. The full interactive estimator remains available when the Astro server endpoint is
        hosted in an environment capable of executing prediction requests.
      </div>
    ) : (
      <>
        <div class="preset-row">
          <button type="button" class="text-button" data-preset="baseline">
            Load baseline profile
          </button>
          <button type="button" class="text-button" data-preset="lowerRisk">
            Load lower-risk profile
          </button>
          <button type="button" class="text-button" data-preset="higherRisk">
            Load higher-risk profile
          </button>
        </div>

        <form id="playground-form" class="playground-form">
          {fieldGroups.map((group) => (
            <fieldset class="playground-group">
              <legend>{group.title}</legend>
              <div class="playground-grid">
                {group.fields.map(([name, label, type]) => (
                  <label class="playground-field">
                    <span>{label}</span>
                    {type === "select" && name === "sex" ? (
                      <select name={name}>
                        <option value="M" selected={defaults[name] === "M"}>Male</option>
                        <option value="F" selected={defaults[name] === "F"}>Female</option>
                      </select>
                    ) : type === "select" && name === "DRK_YN" ? (
                      <select name={name}>
                        <option value="Y" selected={defaults[name] === "Y"}>Alcohol use reported</option>
                        <option value="N" selected={defaults[name] === "N"}>Alcohol use not reported</option>
                      </select>
                    ) : type === "select" ? (
                      <select name={name}>
                        <option value="1" selected={defaults[name] === 1}>Never smoker</option>
                        <option value="2" selected={defaults[name] === 2}>Former smoker</option>
                        <option value="3" selected={defaults[name] === 3}>Current smoker</option>
                      </select>
                    ) : (
                      <input type="number" step="any" name={name} value={defaults[name]} />
                    )}
                  </label>
                ))}
              </div>
            </fieldset>
          ))}

          <div class="form-actions">
            <button type="submit" class="submit-button">
              Submit profile for probabilistic estimation
            </button>
          </div>
        </form>

        <div id="playground-status" class="form-status" aria-live="polite"></div>
        <div id="playground-results" class="playground-results"></div>
      </>
    )}
  </div>
</section>

<script define:vars={{ presets, samplePopulation, isStaticDeployment }}>
  const smokingLabels = {
    1: "Never smoker",
    2: "Former smoker",
    3: "Current smoker",
  };

  const drinkingLabels = {
    Y: "Alcohol use reported",
    N: "Alcohol use not reported",
  };

  if (!isStaticDeployment) {
    const form = document.querySelector("#playground-form");
    const status = document.querySelector("#playground-status");
    const results = document.querySelector("#playground-results");
    const presetButtons = document.querySelectorAll("[data-preset]");
    const runPopulationButton = document.querySelector("#run-population-button");
    const populationStatus = document.querySelector("#population-status");
    const populationResultsBody = document.querySelector("#population-results-body");

    function setStatus(message, isError = false) {
      status.textContent = message;
      status.dataset.state = isError ? "error" : "idle";
    }

    function setPopulationStatus(message, isError = false) {
      populationStatus.textContent = message;
      populationStatus.dataset.state = isError ? "error" : "idle";
    }

    function applyPreset(values) {
      for (const [key, value] of Object.entries(values)) {
        const field = form.elements.namedItem(key);
        if (!field) continue;
        field.value = String(value);
      }
    }

    function labelForSmoking(value) {
      return smokingLabels[value] ?? String(value);
    }

    function labelForDrinking(value) {
      return drinkingLabels[value] ?? String(value);
    }

    async function requestPrediction(payload) {
      const response = await fetch("/api/predict", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify(payload),
      });

      const data = await response.json();

      if (!response.ok) {
        throw new Error(data.error || "Prediction request failed.");
      }

      return data;
    }

    function topProbability(result) {
      return result.probabilities?.[0]?.prob ?? 0;
    }

    function keyMeasures(values) {
      return `Waistline ${values.waistline} cm; BLDS ${values.BLDS} mg/dL; triglyceride ${values.triglyceride} mg/dL; gamma-GTP ${values.gamma_GTP} U/L.`;
    }

    function contextSummary(values) {
      return `Context: ${labelForDrinking(values.DRK_YN)}; ${labelForSmoking(values.SMK_stat_type_cd)}.`;
    }

    function resultCard(title, result, labelMap) {
      const winner = labelMap[result.label] ?? result.label;
      const probabilities = result.probabilities
        .map((entry) => {
          const label = labelMap[entry.label] ?? entry.label;
          return `
            <li>
              <span>${label}</span>
              <strong>${(entry.prob * 100).toFixed(1)}%</strong>
            </li>
          `;
        })
        .join("");

      return `
        <article class="result-card">
          <h4>${title}</h4>
          <p class="result-winner">${winner}</p>
          <ul>${probabilities}</ul>
        </article>
      `;
    }

    function renderPopulationResults(rows) {
      populationResultsBody.innerHTML = rows
        .map((row) => {
          const smokingWinner = labelForSmoking(row.prediction.smoking.label);
          const drinkingWinner = labelForDrinking(row.prediction.drinking.label);
          const smokingConfidence = (topProbability(row.prediction.smoking) * 100).toFixed(1);
          const drinkingConfidence = (topProbability(row.prediction.drinking) * 100).toFixed(1);

            return `
              <tr>
                <td class="prediction-profile">${row.person.name}</td>
                <td>${row.person.blurb}</td>
                <td>
                  <div class="prediction-stack prediction-measures">
                    <span>${keyMeasures(row.person.values)}</span>
                    <span>${contextSummary(row.person.values)}</span>
                  </div>
                </td>
                <td>
                  <div class="prediction-stack prediction-estimate">
                    <strong>${smokingWinner}</strong>
                    <span>${smokingConfidence}% probability</span>
                  </div>
                </td>
                <td>
                  <div class="prediction-stack prediction-estimate">
                    <strong>${drinkingWinner}</strong>
                    <span>${drinkingConfidence}% probability</span>
                  </div>
                </td>
              </tr>
            `;
          })
        .join("");
    }

    presetButtons.forEach((button) => {
      button.addEventListener("click", () => {
        applyPreset(presets[button.dataset.preset]);
        setStatus(`The ${button.textContent?.trim()} has been loaded into the estimator.`);
      });
    });

    runPopulationButton?.addEventListener("click", async () => {
      setPopulationStatus("Estimating class probabilities for the representative profiles...");
      runPopulationButton.disabled = true;

      try {
        const rows = await Promise.all(
          samplePopulation.map(async (person) => ({
            person,
            prediction: await requestPrediction(person.values),
          })),
        );

        renderPopulationResults(rows);
        setPopulationStatus("Representative-profile estimation completed.");
      } catch (error) {
        setPopulationStatus(error.message || "Profile estimation failed.", true);
      } finally {
        runPopulationButton.disabled = false;
      }
    });

    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      setStatus("Submitting the profile for estimation...");
      results.innerHTML = "";

      const payload = Object.fromEntries(new FormData(form).entries());

      try {
        const data = await requestPrediction(payload);
        setStatus(`Estimation completed at ${new Date(data.predictedAt).toLocaleString("en-US")}.`);
        results.innerHTML = `
          ${resultCard("Smoking classifier", data.smoking, smokingLabels)}
          ${resultCard("Drinking classifier", data.drinking, drinkingLabels)}
        `;
      } catch (error) {
        setStatus(error.message || "Estimation failed.", true);
      }
    });
  }
</script>
