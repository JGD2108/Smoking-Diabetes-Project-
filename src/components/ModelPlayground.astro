---
const defaults = Astro.props.defaults;
const deploymentTarget = import.meta.env.PUBLIC_DEPLOYMENT_TARGET ?? "server";
const isStaticDeployment = deploymentTarget === "github-pages";

const smokingContextLabels = {
  1: "Never smoker",
  2: "Former smoker",
  3: "Current smoker",
};

const drinkingLabels = {
  Y: "Alcohol use reported",
  N: "Alcohol use not reported",
};

const fieldGroups = [
  {
    title: "Anthropometric and demographic variables",
    fields: [
      ["sex", "Sex", "select"],
      ["age", "Age", "number"],
      ["height", "Height (cm)", "number"],
      ["weight", "Weight (kg)", "number"],
      ["waistline", "Waist circumference (cm)", "number"],
    ],
  },
  {
    title: "Sensory and hemodynamic measures",
    fields: [
      ["sight_left", "Left-eye acuity", "number"],
      ["sight_right", "Right-eye acuity", "number"],
      ["hear_left", "Left-ear screening", "number"],
      ["hear_right", "Right-ear screening", "number"],
      ["SBP", "Systolic blood pressure", "number"],
      ["DBP", "Diastolic blood pressure", "number"],
      ["BLDS", "Fasting glucose", "number"],
    ],
  },
  {
    title: "Laboratory biomarkers",
    fields: [
      ["tot_chole", "Total cholesterol", "number"],
      ["HDL_chole", "HDL cholesterol", "number"],
      ["LDL_chole", "LDL cholesterol", "number"],
      ["triglyceride", "Triglycerides", "number"],
      ["hemoglobin", "Hemoglobin", "number"],
      ["urine_protein", "Urine protein score", "number"],
      ["serum_creatinine", "Serum creatinine", "number"],
      ["SGOT_AST", "SGOT AST", "number"],
      ["SGOT_ALT", "SGOT ALT", "number"],
      ["gamma_GTP", "Gamma-GTP", "number"],
    ],
  },
  {
    title: "Behavioral context variables",
    fields: [
      ["DRK_YN", "Known alcohol-use context", "select"],
      ["SMK_stat_type_cd", "Known smoking-status context", "select"],
