    },
  },
];

const staticPopulationPredictions = {
  young_social_smoker: {
    smoking: {
      label: "3",
      probabilities: [
        { label: "3", prob: 0.48906755447387695 },
        { label: "1", prob: 0.26785486936569214 },
        { label: "2", prob: 0.24307756125926971 },
      ],
    },
    drinking: {
      label: "Y",
      probabilities: [
        { label: "Y", prob: 0.8197373151779175 },
        { label: "N", prob: 0.1802627295255661 },
      ],
    },
  },
  former_smoker_office_worker: {
    smoking: {
      label: "2",
      probabilities: [
        { label: "2", prob: 0.3821558952331543 },
        { label: "1", prob: 0.3650178909301758 },
        { label: "3", prob: 0.25282618403434753 },
      ],
    },
    drinking: {
      label: "Y",
      probabilities: [
        { label: "Y", prob: 0.7465388774871826 },
        { label: "N", prob: 0.25346115231513977 },
      ],
    },
  },
  healthy_retired_woman: {
    smoking: {
      label: "1",
      probabilities: [
        { label: "1", prob: 0.8176808953285217 },
        { label: "3", prob: 0.0914359986782074 },
        { label: "2", prob: 0.0908830463886261 },
      ],
    },
    drinking: {
      label: "N",
      probabilities: [
        { label: "N", prob: 0.8564013838768005 },
        { label: "Y", prob: 0.14359867572784424 },
      ],
    },
  },
  metabolic_high_risk: {
    smoking: {
      label: "2",
      probabilities: [
        { label: "2", prob: 0.38344934582710266 },
        { label: "3", prob: 0.37481266260147095 },
        { label: "1", prob: 0.2417379915714264 },
      ],
    },
    drinking: {
      label: "Y",
      probabilities: [
        { label: "Y", prob: 0.8085731863975525 },
        { label: "N", prob: 0.1914268136024475 },
      ],
    },
  },
  balanced_urban_professional: {
    smoking: {
      label: "1",
      probabilities: [
        { label: "1", prob: 0.7628682851791382 },
        { label: "2", prob: 0.12017732858657837 },
        { label: "3", prob: 0.11695435643196106 },
      ],
    },
    drinking: {
      label: "N",
      probabilities: [
        { label: "N", prob: 0.5840172171592712 },
        { label: "Y", prob: 0.41598284244537354 },
      ],
    },
  },
};

function labelForSmoking(value) {
  return smokingContextLabels[value] ?? String(value);
}

function labelForDrinking(value) {
  return drinkingLabels[value] ?? String(value);
}

function topProbability(result) {
  return result.probabilities?.[0]?.prob ?? 0;
}

function summarize(rows, selector) {
  const counts = rows.reduce((acc, row) => {
    const key = selector(row);
    acc[key] = (acc[key] ?? 0) + 1;
    return acc;
  }, {});

  return Object.entries(counts)
    .map(([label, count]) => `${label}: ${count}`)
    .join(" | ");
}

const staticPopulationRows = samplePopulation
  .map((person) => ({
    person,
    prediction: staticPopulationPredictions[person.id],
  }))
  .filter((row) => row.prediction);

const staticSmokingSummary = summarize(
  staticPopulationRows,
  (row) => labelForSmoking(row.prediction.smoking.label),
);
const staticDrinkingSummary = summarize(
  staticPopulationRows,
  (row) => labelForDrinking(row.prediction.drinking.label),
);
---

<section class="playground">
  <div class="playground-intro">
    <h3>Prediction explorer</h3>
    <p>
      Smoking and drinking often appear together in the same health profile, so the detailed view
      includes both lifestyle context fields to keep the results grounded in the broader picture.
    </p>
    {isStaticDeployment && (
      <p class="playground-hint">
        This published version highlights a ready-made five-person comparison for a faster
        experience.
      </p>
    )}
  </div>

  <section class="population-panel">
    <div class="population-head">
      <div class="population-copy">
        <p class="result-kicker">Quick Compare</p>
        <h3>Run a sample population of 5 people</h3>
        <p>
          Start with a curated mini-population. It compares five realistic profiles and shows the
          most important outputs in one table.
        </p>
      </div>
      {!isStaticDeployment && (
        <button type="button" class="primary-button" id="run-population-button">
          Simulate 5 people
        </button>
      )}
    </div>

    <div class="persona-grid">
      {samplePopulation.map((person) => (
        <article class="persona-card">
          <div class="persona-card-head">
            <div>
              <h4>{person.name}</h4>
              <p>{person.blurb}</p>
            </div>
            {!isStaticDeployment && (
              <button
                type="button"
                class="preset-button persona-load-button"
                data-persona={person.id}
              >
                Use in form
              </button>
            )}
          </div>

          <div class="persona-meta">
            <span>{person.values.sex === "M" ? "Male" : "Female"}</span>
            <span>{person.values.age} years</span>
            <span>Waist {person.values.waistline}</span>
            <span>BLDS {person.values.BLDS}</span>
            <span>Gamma {person.values.gamma_GTP}</span>
            <span>Drinking context {labelForDrinking(person.values.DRK_YN)}</span>
            <span>Smoking context {labelForSmoking(person.values.SMK_stat_type_cd)}</span>
          </div>
        </article>
      ))}
    </div>

    {isStaticDeployment ? (
      <>
        <div class="playground-status">
          Showing a precomputed sample based on the current model snapshot.
        </div>

        <div class="population-summary-grid">
          <article class="population-stat">
            <p class="result-kicker">Smoking split</p>
            <strong>{staticSmokingSummary}</strong>
          </article>
          <article class="population-stat">
            <p class="result-kicker">Drinking split</p>
            <strong>{staticDrinkingSummary}</strong>
          </article>
        </div>

        <div class="population-results-shell">
          <div class="table-scroll">
            <table class="population-table">
              <thead>
                <tr>
                  <th>Profile</th>
                  <th>Key inputs</th>
                  <th>Drinking context</th>
                  <th>Smoking context</th>
                  <th>Predicted smoking</th>
                  <th>Smoking confidence</th>
                  <th>Predicted drinking</th>
                  <th>Drinking confidence</th>
                </tr>
              </thead>
              <tbody>
                {staticPopulationRows.map(({ person, prediction }) => (
                  <tr>
                    <td>
                      <strong>{person.name}</strong>
                      <div class="population-subtle">{person.blurb}</div>
                    </td>
                    <td>
                      {person.values.sex === "M" ? "Male" : "Female"}, {person.values.age}y
                      <br />
                      Waist {person.values.waistline}, BLDS {person.values.BLDS}, Gamma{" "}
                      {person.values.gamma_GTP}
                    </td>
                    <td>{labelForDrinking(person.values.DRK_YN)}</td>
                    <td>{labelForSmoking(person.values.SMK_stat_type_cd)}</td>
                    <td>
                      <strong>{labelForSmoking(prediction.smoking.label)}</strong>
                    </td>
                    <td>{(topProbability(prediction.smoking) * 100).toFixed(1)}%</td>
                    <td>
                      <strong>{labelForDrinking(prediction.drinking.label)}</strong>
                    </td>
                    <td>{(topProbability(prediction.drinking) * 100).toFixed(1)}%</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </>
    ) : (
      <>
        <div id="population-status" class="playground-status" aria-live="polite"></div>
        <div id="population-summary" class="population-summary-grid"></div>
        <div id="population-results" class="population-results-shell" hidden></div>
      </>
    )}
  </section>

  <section class="manual-panel">
    <div class="manual-head">
      <div>
        <p class="result-kicker">Detailed View</p>
        <h3>Explore an individual profile</h3>
      </div>
      {!isStaticDeployment && (
        <div class="preset-row">
          <button type="button" class="preset-button" data-preset="baseline">Typical profile</button>
          <button type="button" class="preset-button" data-preset="lowerRisk">
            Lower-risk profile
          </button>
          <button type="button" class="preset-button" data-preset="higherRisk">
            Higher-risk profile
          </button>
        </div>
      )}
    </div>

    {isStaticDeployment ? (
      <article class="notes-card playground-disabled">
        <h3>Expanded interaction is available in the live version</h3>
        <p>
          This published version focuses on the five-profile comparison so visitors can review the
          results quickly and clearly.
        </p>
        <p>
          The full interactive form remains available in the live app environment used for direct
          prediction requests.
        </p>
      </article>
    ) : (
      <>
        <form id="playground-form" class="playground-form">
          {fieldGroups.map((group) => (
            <fieldset class="playground-group">
              <legend>{group.title}</legend>
              <div class="playground-grid">
                {group.fields.map(([name, label, type]) => (
                  <label class="playground-field">
                    <span>{label}</span>
                    {type === "select" && name === "sex" ? (
                      <select name={name}>
                        <option value="M" selected={defaults[name] === "M"}>Male</option>
                        <option value="F" selected={defaults[name] === "F"}>Female</option>
                      </select>
                    ) : type === "select" && name === "DRK_YN" ? (
                      <select name={name}>
                        <option value="Y" selected={defaults[name] === "Y"}>Y</option>
                        <option value="N" selected={defaults[name] === "N"}>N</option>
                      </select>
                    ) : type === "select" ? (
                      <select name={name}>
                        <option value="1" selected={defaults[name] === 1}>1 - never</option>
                        <option value="2" selected={defaults[name] === 2}>2 - quit</option>
                        <option value="3" selected={defaults[name] === 3}>3 - still smoking</option>
                      </select>
                    ) : (
                      <input type="number" step="any" name={name} value={defaults[name]} />
                    )}
                  </label>
                ))}
              </div>
            </fieldset>
          ))}

          <div class="playground-actions">
            <button type="submit" class="primary-button">Run prediction</button>
            <p class="playground-hint">
              The quick comparison above is the easiest way to start. Use this detailed form for
              case-by-case exploration.
            </p>
          </div>
        </form>

        <div id="playground-status" class="playground-status" aria-live="polite"></div>
        <div id="playground-results" class="playground-results"></div>
      </>
    )}
  </section>
</section>

<script define:vars={{ presets, samplePopulation, isStaticDeployment }}>
  const smokingLabels = {
    1: "Never",
    2: "Quit",
    3: "Still smoke",
  };

  const drinkingLabels = {
    Y: "Drinker",
    N: "Non-drinker",
  };

  if (!isStaticDeployment) {
    const form = document.querySelector("#playground-form");
    const status = document.querySelector("#playground-status");
    const results = document.querySelector("#playground-results");
    const presetButtons = document.querySelectorAll("[data-preset]");
    const personaButtons = document.querySelectorAll("[data-persona]");
    const runPopulationButton = document.querySelector("#run-population-button");
    const populationStatus = document.querySelector("#population-status");
    const populationSummary = document.querySelector("#population-summary");
    const populationResults = document.querySelector("#population-results");

    function setStatus(message, isError = false) {
      status.textContent = message;
      status.dataset.state = isError ? "error" : "idle";
    }

    function setPopulationStatus(message, isError = false) {
      populationStatus.textContent = message;
      populationStatus.dataset.state = isError ? "error" : "idle";
    }

    function applyPreset(values) {
      for (const [key, value] of Object.entries(values)) {
        const field = form.elements.namedItem(key);
        if (!field) continue;
        field.value = String(value);
      }
    }

    function labelForSmoking(value) {
      return smokingLabels[value] ?? String(value);
    }

    function labelForDrinking(value) {
      return drinkingLabels[value] ?? String(value);
    }

    async function requestPrediction(payload) {
      const response = await fetch("/api/predict", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify(payload),
      });

      const data = await response.json();

      if (!response.ok) {
        throw new Error(data.error || "Prediction request failed");
      }

      return data;
    }

    function resultCard(title, result, labelMap) {
      const probabilities = result.probabilities
        .map((entry) => {
          const label = labelMap[entry.label] ?? entry.label;
          return `
            <li>
              <span>${label}</span>
              <strong>${(entry.prob * 100).toFixed(1)}%</strong>
            </li>
          `;
        })
        .join("");

      const winner = labelMap[result.label] ?? result.label;

      return `
        <article class="result-card">
          <p class="result-kicker">${title}</p>
          <h4>${winner}</h4>
          <ul>${probabilities}</ul>
        </article>
      `;
    }

    function topProbability(result) {
      return result.probabilities?.[0]?.prob ?? 0;
    }

    function renderPopulationSummary(rows) {
      const smokingCounts = rows.reduce((acc, row) => {
        const key = labelForSmoking(row.prediction.smoking.label);
        acc[key] = (acc[key] ?? 0) + 1;
        return acc;
      }, {});

      const drinkingCounts = rows.reduce((acc, row) => {
        const key = labelForDrinking(row.prediction.drinking.label);
        acc[key] = (acc[key] ?? 0) + 1;
        return acc;
      }, {});

      const smokingSummary = Object.entries(smokingCounts)
        .map(([label, count]) => `${label}: ${count}`)
        .join(" | ");

      const drinkingSummary = Object.entries(drinkingCounts)
        .map(([label, count]) => `${label}: ${count}`)
        .join(" | ");

      populationSummary.innerHTML = `
        <article class="population-stat">
          <p class="result-kicker">Smoking split</p>
          <strong>${smokingSummary || "No results yet"}</strong>
        </article>
        <article class="population-stat">
          <p class="result-kicker">Drinking split</p>
          <strong>${drinkingSummary || "No results yet"}</strong>
        </article>
      `;
    }

    function renderPopulationResults(rows) {
      const tableRows = rows
        .map((row) => {
          const smokingWinner = labelForSmoking(row.prediction.smoking.label);
          const drinkingWinner = labelForDrinking(row.prediction.drinking.label);
          const smokingConfidence = (topProbability(row.prediction.smoking) * 100).toFixed(1);
          const drinkingConfidence = (topProbability(row.prediction.drinking) * 100).toFixed(1);

          return `
            <tr>
              <td>
                <strong>${row.person.name}</strong>
                <div class="population-subtle">${row.person.blurb}</div>
              </td>
              <td>
                ${row.person.values.sex === "M" ? "Male" : "Female"}, ${row.person.values.age}y
                <br />
                Waist ${row.person.values.waistline}, BLDS ${row.person.values.BLDS}, Gamma ${row.person.values.gamma_GTP}
              </td>
              <td>${labelForDrinking(row.person.values.DRK_YN)}</td>
              <td>${labelForSmoking(row.person.values.SMK_stat_type_cd)}</td>
              <td><strong>${smokingWinner}</strong></td>
              <td>${smokingConfidence}%</td>
              <td><strong>${drinkingWinner}</strong></td>
              <td>${drinkingConfidence}%</td>
            </tr>
          `;
        })
        .join("");

      populationResults.hidden = false;
      populationResults.innerHTML = `
        <div class="table-scroll">
          <table class="population-table">
            <thead>
              <tr>
                <th>Profile</th>
                <th>Key inputs</th>
                <th>Drinking context</th>
                <th>Smoking context</th>
                <th>Predicted smoking</th>
                <th>Smoking confidence</th>
                <th>Predicted drinking</th>
                <th>Drinking confidence</th>
              </tr>
            </thead>
            <tbody>${tableRows}</tbody>
          </table>
        </div>
      `;
    }

    presetButtons.forEach((button) => {
      button.addEventListener("click", () => {
        applyPreset(presets[button.dataset.preset]);
        setStatus(`Loaded ${button.textContent?.trim()} preset.`);
      });
    });

    personaButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const person = samplePopulation.find((entry) => entry.id === button.dataset.persona);
        if (!person) return;
        applyPreset(person.values);
        setStatus(`Loaded ${person.name} into the detailed form.`);
        form.scrollIntoView({ behavior: "smooth", block: "start" });
      });
    });

    runPopulationButton?.addEventListener("click", async () => {
      setPopulationStatus("Running predictions for 5 sample profiles...");
      runPopulationButton.disabled = true;
      populationResults.hidden = true;
      populationResults.innerHTML = "";
      populationSummary.innerHTML = "";

      try {
        const rows = await Promise.all(
          samplePopulation.map(async (person) => ({
            person,
            prediction: await requestPrediction(person.values),
          })),
        );

        renderPopulationSummary(rows);
        renderPopulationResults(rows);
        setPopulationStatus(
          `Population simulation completed at ${new Date().toLocaleString()}.`,
        );
      } catch (error) {
        setPopulationStatus(error.message || "Population simulation failed.", true);
      } finally {
        runPopulationButton.disabled = false;
      }
    });

    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      setStatus("Running prediction...");
      results.innerHTML = "";

      const payload = Object.fromEntries(new FormData(form).entries());

      try {
        const data = await requestPrediction(payload);
        setStatus(`Prediction completed at ${new Date(data.predictedAt).toLocaleString()}.`);
        results.innerHTML = `
          ${resultCard("Smoking model", data.smoking, smokingLabels)}
          ${resultCard("Drinking model", data.drinking, drinkingLabels)}
        `;
      } catch (error) {
        setStatus(error.message || "Prediction failed.", true);
      }
    });
  }
</script>
