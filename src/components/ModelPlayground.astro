---
const defaults = Astro.props.defaults;
const deploymentTarget = import.meta.env.PUBLIC_DEPLOYMENT_TARGET ?? "server";
const isStaticDeployment = deploymentTarget === "github-pages";

const smokingContextLabels = {
  1: "Never",
  2: "Quit",
  3: "Still smoke",
};

const drinkingLabels = {
  Y: "Drinker",
  N: "Non-drinker",
};

const fieldGroups = [
  {
    title: "Demographics",
    fields: [
      ["sex", "Sex", "select"],
      ["age", "Age", "number"],
      ["height", "Height (cm)", "number"],
      ["weight", "Weight (kg)", "number"],
      ["waistline", "Waistline", "number"],
    ],
  },
  {
    title: "Senses and vitals",
    fields: [
      ["sight_left", "Sight left", "number"],
      ["sight_right", "Sight right", "number"],
      ["hear_left", "Hear left", "number"],
      ["hear_right", "Hear right", "number"],
      ["SBP", "SBP", "number"],
      ["DBP", "DBP", "number"],
      ["BLDS", "BLDS", "number"],
    ],
  },
  {
    title: "Lab signals",
    fields: [
      ["tot_chole", "Total cholesterol", "number"],
      ["HDL_chole", "HDL cholesterol", "number"],
      ["LDL_chole", "LDL cholesterol", "number"],
      ["triglyceride", "Triglycerides", "number"],
      ["hemoglobin", "Hemoglobin", "number"],
      ["urine_protein", "Urine protein", "number"],
      ["serum_creatinine", "Serum creatinine", "number"],
      ["SGOT_AST", "SGOT AST", "number"],
      ["SGOT_ALT", "SGOT ALT", "number"],
      ["gamma_GTP", "Gamma GTP", "number"],
    ],
  },
  {
    title: "Lifestyle context",
    fields: [
      ["DRK_YN", "Drinking context", "select"],
      ["SMK_stat_type_cd", "Smoking context", "select"],
    ],
  },
];

const presets = {
  baseline: defaults,
  lowerRisk: {
    ...defaults,
    sex: "F",
    age: 65,
    height: 160,
    weight: 58,
    waistline: 77,
    BLDS: 88,
