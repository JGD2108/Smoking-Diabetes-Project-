---
interface FeatureRow {
  feature: string;
  weight: number;
  gain: number;
}

interface Props {
  title: string;
  rows: FeatureRow[];
}

const { title, rows } = Astro.props;
const maxWeight = Math.max(...rows.map((row) => row.weight));
---

<article class="figure-panel">
  <p class="figure-panel-title">{title}</p>
  <div class="bar-list">
    {rows.map((row) => {
      const width = maxWeight === 0 ? 0 : (row.weight / maxWeight) * 100;
      return (
        <div class="bar-row">
          <div class="bar-meta">
            <span class="bar-feature">{row.feature}</span>
            <span class="bar-values">
              split frequency {row.weight.toLocaleString("en-US")} | gain {row.gain.toFixed(2)}
            </span>
          </div>
          <div class="bar-track">
            <div class="bar-fill" style={`width:${width}%`}></div>
          </div>
        </div>
      );
    })}
  </div>
</article>
