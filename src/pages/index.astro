---
import siteData from "../data/siteData.generated.json";
import {
  architectureFlow,
  dashboardNotes,
  edaFigures,
  modelContextNotes,
  projectLinks,
  references,
  sampleRows,
  siteMeta,
  variableDescriptions,
} from "../data/content";
import ConfusionMatrix from "../components/ConfusionMatrix.astro";
import DashboardEmbed from "../components/DashboardEmbed.astro";
import FeatureImportanceBars from "../components/FeatureImportanceBars.astro";
import MetricCard from "../components/MetricCard.astro";
import ModelPlayground from "../components/ModelPlayground.astro";
import SectionHeading from "../components/SectionHeading.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const latestSmoking = siteData.models.latestMetrics.smoking_rf_model;
const latestDrinking = siteData.models.latestMetrics.drinking_rf_model;
const latestRun = siteData.cloudPipeline.latestRun;
const latestPromotion = siteData.cloudPipeline.promotions[0];
const basePath = import.meta.env.BASE_URL;

const smokingLabelMap = {
  "1": "Never",
  "2": "Quit",
  "3": "Still smoke",
};

const drinkingLabelMap = {
  N: "Non-drinker",
  Y: "Drinker",
};

function metricDelta(current, baseline) {
  const delta = current - baseline;
  const sign = delta >= 0 ? "+" : "";
  return `${sign}${(delta * 100).toFixed(1)} pts`;
}

function withBase(path) {
  const cleanBase = basePath.endsWith("/") ? basePath : `${basePath}/`;
  return `${cleanBase}${String(path).replace(/^\/+/, "")}`;
}

function formatTimestamp(value, fallback = "Recent update") {
  if (!value || value === "[object Object]") return fallback;
  const parsed = new Date(value);
  return Number.isNaN(parsed.getTime()) ? String(value) : parsed.toLocaleString();
}

function formatSchedule(value) {
  if (!value) return "Scheduled";
  const knownSchedules = {
    "0 3 * * 1": "Weekly",
  };
  return knownSchedules[value] ?? value;
}

function formatCheckName(value) {
  const labels = {
    unique_row_id_check: "Duplicate record check",
    rowcount_check: "Row volume check",
    valid_values_check: "Valid values check",
  };

  return labels[value] ?? String(value).replace(/_/g, " ");
}

function formatAlert(value) {
  if (value?.includes("Workflow failure")) {
    return "Automatic monitoring flags any failed refresh.";
  }

  if (value?.includes("Missing scheduled run")) {
    return "Automatic monitoring alerts the team if a scheduled refresh is missed.";
  }

  return value;
}
---

<BaseLayout title={siteMeta.title} description={siteMeta.description}>
  <header class="site-header">
    <a href="#top" class="brand">
      <span class="brand-mark">SD</span>
      <span>
        <strong>Smoking and Drinking Prediction</strong>
        <small>Interactive health insights</small>
      </span>
    </a>

    <nav class="site-nav">
      <a href="#overview">Overview</a>
      <a href="#dataset">Dataset</a>
      <a href="#eda">Insights</a>
      <a href="#pipeline">System</a>
      <a href="#models">Models</a>
      <a href="#dashboard">Dashboard</a>
      <a href="#playground">Playground</a>
      <button type="button" class="theme-button" data-theme-toggle>
        Theme
      </button>
    </nav>
  </header>

  <main id="top">
    <section class="hero">
      <div class="hero-copy">
        <p class="eyebrow">Behavior and Health Insights</p>
        <h1>Smoking and Drinking Prediction</h1>
        <p class="hero-lead">
          Explore how body signals relate to smoking and drinking patterns.
        </p>
        <p class="hero-body">
          This experience combines population-level analysis, interactive model views, and a
          multi-page dashboard in one place, making it easier to move from broad health patterns
          to concrete profile-based examples.
        </p>

        <div class="hero-links">
          {projectLinks.map((link) => (
            <a href={link.href} target="_blank" rel="noreferrer" class="chip-link">
              {link.label}
            </a>
          ))}
        </div>

        <div class="hero-jump-links">
          <a href="#dashboard" class="hero-inline-link">Jump to dashboard</a>
          <a href="#playground" class="hero-inline-link">Try live prediction</a>
        </div>
      </div>

      <div class="hero-panel">
        <p class="eyebrow panel-eyebrow">Project Snapshot</p>
        <div class="hero-grid">
          <MetricCard
            label="Raw dataset rows"
            value={siteData.dataset.observations.toLocaleString()}
            note="Anonymized health records"
          />
          <MetricCard
            label="Rows preserved in staging"
            value={`${siteData.cloudPipeline.preservedPct}%`}
            note={`${siteData.cloudPipeline.stageCounts.staging.toLocaleString()} clean rows`}
          />
          <MetricCard
            label="Predictive models"
            value="2"
            note="Smoking and drinking classifiers"
          />
          <MetricCard
            label="Refresh cadence"
            value={formatSchedule(siteData.project.schedulerJobs[0]?.schedule)}
            note={siteData.project.schedulerJobs[0]?.state ?? "Automatic refresh"}
          />
        </div>

        <div class="hero-note">
          <p>
            <strong>Start anywhere.</strong> Browse the embedded dashboard, inspect the population
            charts, or compare individual profiles in the prediction explorer below.
          </p>
          <p class="hero-note-meta">
            Latest system status: {latestRun?.finalStatus ?? "SUCCESS"}
          </p>
        </div>
      </div>
    </section>

    <div class="content-shell">
      <aside class="page-outline" aria-label="Page outline">
        <p class="outline-label">On this page</p>
        <a href="#overview">Overview</a>
        <a href="#dataset">Dataset</a>
        <a href="#eda">Insights</a>
        <a href="#pipeline">System</a>
        <a href="#models">Models</a>
        <a href="#dashboard">Dashboard</a>
        <a href="#playground">Playground</a>
        <a href="#references">References</a>
      </aside>

      <div class="content-stack">
        <section id="overview" class="section">
          <SectionHeading
            kicker="Overview"
            title="A clearer view of smoking and drinking patterns"
            intro="This site brings together health indicators, behavior-linked trends, and predictive outputs so visitors can understand how everyday body signals relate to smoking and drinking outcomes."
          />

          <div class="insight-grid">
            <article class="insight-card">
              <h3>Population scale</h3>
              <p>
                The dataset covers {siteData.dataset.observations.toLocaleString()} health records,
                giving the analysis a broad view of how biometric and lifestyle signals move
                together across many different profiles.
              </p>
            </article>
            <article class="insight-card">
              <h3>Behavior signals</h3>
              <p>
                Waistline, blood pressure, glucose, cholesterol, triglycerides, and liver markers
                all contribute to recognizable patterns that help explain smoking and drinking
                behavior.
              </p>
            </article>
            <article class="insight-card">
              <h3>Interactive exploration</h3>
              <p>
                Visitors can move from big-picture charts to a multi-page dashboard and then into
                profile-based prediction examples without needing any technical background.
              </p>
            </article>
          </div>
        </section>

        <section id="dataset" class="section">
          <SectionHeading
            kicker="Dataset"
            title="Health signals from the Korean National Health Insurance Service"
            intro="The dataset brings together anonymized health measurements and lifestyle labels, making it possible to study both broad population patterns and profile-level prediction outcomes."
          />

          <div class="metric-grid">
            <MetricCard label="Observations" value={siteData.dataset.observations.toLocaleString()} />
            <MetricCard label="Variables" value={String(siteData.dataset.variables)} />
            <MetricCard label="Completeness" value={siteData.dataset.completeness} />
            <MetricCard
              label="Project"
              value={siteData.project.id}
              note={siteData.project.location}
            />
          </div>

          <div class="table-card">
            <h3>Sample rows</h3>
            <div class="table-scroll">
              <table>
                <thead>
                  <tr>
                    {Object.keys(sampleRows[0]).map((key) => <th>{key}</th>)}
                  </tr>
                </thead>
                <tbody>
                  {sampleRows.map((row) => (
                    <tr>
                      {Object.values(row).map((value) => <td>{String(value)}</td>)}
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>

          <div class="variables-grid">
            {variableDescriptions.map(([name, description]) => (
              <article class="variable-card">
                <h3>{name}</h3>
                <p>{description}</p>
              </article>
            ))}
          </div>
        </section>

        <section id="eda" class="section">
          <SectionHeading
            kicker="Population Insights"
            title="Key patterns across the population"
            intro="These charts highlight how age, sex, and biometric measures vary across smoking and drinking groups, helping visitors spot the most meaningful patterns at a glance."
          />

          <div class="eda-grid">
            {edaFigures.map((figure) => (
              <article class="eda-card">
                <a href={withBase(figure.src)} target="_blank" rel="noreferrer" class="eda-media">
                  <img src={withBase(figure.src)} alt={figure.alt} loading="lazy" />
                </a>
                <div class="eda-copy">
                  <h3>{figure.title}</h3>
                  <p>{figure.summary}</p>
                  <a href={withBase(figure.src)} target="_blank" rel="noreferrer" class="eda-link">
                    Open full figure
                  </a>
                </div>
              </article>
            ))}
          </div>

          <div class="compare-grid">
            <article class="compare-card">
              <p class="eyebrow">Population coverage</p>
              <h3>The analysis spans a broad range of health profiles</h3>
              <p>
                With {siteData.dataset.observations.toLocaleString()} records and{" "}
                {siteData.dataset.variables} variables, the dataset captures meaningful variation
                across demographics, vitals, and lab measurements.
              </p>
            </article>
            <article class="compare-card emphasis">
              <p class="eyebrow">Data consistency</p>
              <h3>Only a very small share of records are excluded during quality screening</h3>
              <p>
                The working dataset retains{" "}
                {siteData.cloudPipeline.stageCounts.staging.toLocaleString()} rows, preserving
                nearly the full population while removing clear duplicates and invalid records.
              </p>
            </article>
          </div>

          <article class="notes-card">
            <h3>How to read these charts</h3>
            <ul class="note-list">
              <li>
                These visuals show population-level patterns rather than individual medical advice.
              </li>
              <li>
                Differences become more meaningful when several indicators move in the same
                direction.
              </li>
              <li>
                Use the scenario table and prediction explorer below to translate these patterns
                into concrete examples.
              </li>
            </ul>
          </article>
        </section>

        <section id="pipeline" class="section">
          <SectionHeading
            kicker="System Overview"
            title="How the data and predictions stay current"
            intro="Behind the scenes, the project organizes records, quality checks, model refreshes, and reporting into a scheduled flow so the experience remains consistent over time."
          />

          <div class="flow-card">
            {architectureFlow.map((step, index) => (
              <div class="flow-step">
                <span>{index + 1}</span>
                <p>{step}</p>
              </div>
            ))}
          </div>

          <div class="metric-grid">
            <MetricCard
              label="Refresh workflow"
              value={siteData.project.workflow?.name ?? "health-pipeline"}
              note={siteData.project.workflow?.state ?? "ACTIVE"}
            />
            <MetricCard
              label="Latest refresh"
              value={latestRun?.finalStatus ?? "SUCCESS"}
              note={formatTimestamp(latestRun?.runTimestamp, "Most recent run")}
            />
            <MetricCard
              label="Records removed"
              value={siteData.cloudPipeline.duplicatesRemoved.toLocaleString()}
              note="duplicate or invalid entries"
            />
            <MetricCard
              label="Model status"
              value={latestPromotion?.status ?? "APPROVED"}
              note={latestPromotion?.notes ?? "Meets current quality threshold"}
            />
          </div>

          <div class="chart-grid two-up">
            <article class="chart-card">
              <div class="chart-head">
                <h3>Recent refresh history</h3>
              </div>
              <div class="timeline-list">
                {siteData.cloudPipeline.pipelineRuns.map((run, index) => (
                  <div class="timeline-item">
                    <div>
                      <strong>Refresh {index + 1}</strong>
                      <p>{formatTimestamp(run.runTimestamp, run.pipelineRunId)}</p>
                    </div>
                    <p>
                      {run.stagingRowCount.toLocaleString()} clean rows - {run.finalStatus}
                    </p>
                  </div>
                ))}
              </div>
            </article>

            <article class="chart-card">
              <div class="chart-head">
                <h3>Validation checks</h3>
              </div>
              <div class="timeline-list">
                {siteData.cloudPipeline.dataQualityChecks.map((check) => (
                  <div class="timeline-item">
                    <div>
                      <strong>{formatCheckName(check.name)}</strong>
                      <p>{formatTimestamp(check.timestamp, "Latest validation")}</p>
                    </div>
                    <p>{check.status} - {check.failedRows} failed rows</p>
                  </div>
                ))}
              </div>
            </article>
          </div>

          <article class="notes-card">
            <h3>Reliability notes</h3>
            <ul class="note-list">
              {siteData.project.alerting.map((note) => <li>{formatAlert(note)}</li>)}
            </ul>
          </article>
        </section>

        <section id="models" class="section">
          <SectionHeading
            kicker="Model Insights"
            title="How the predictors read smoking and drinking patterns"
            intro="This section summarizes overall model performance, highlights the strongest input signals, and shows where predictions are most accurate."
          />

          <div class="chart-grid two-up">
            <article class="chart-card compare-panel">
              <div class="chart-head">
                <h3>Smoking classifier</h3>
              </div>
              <div class="model-metrics">
                <div>
                  <p class="metric-label">Baseline accuracy</p>
                  <strong>{(siteData.notebookBaseline.smoking.accuracy * 100).toFixed(1)}%</strong>
                </div>
                <div>
                  <p class="metric-label">Current accuracy</p>
                  <strong>{(latestSmoking.accuracy * 100).toFixed(1)}%</strong>
                  <small>
                    {metricDelta(latestSmoking.accuracy, siteData.notebookBaseline.smoking.accuracy)}
                  </small>
                </div>
                <div>
                  <p class="metric-label">Baseline F1</p>
                  <strong>{siteData.notebookBaseline.smoking.f1.toFixed(3)}</strong>
                </div>
                <div>
                  <p class="metric-label">Current F1</p>
                  <strong>{latestSmoking.f1.toFixed(3)}</strong>
                  <small>{metricDelta(latestSmoking.f1, siteData.notebookBaseline.smoking.f1)}</small>
                </div>
              </div>
            </article>

            <article class="chart-card compare-panel">
              <div class="chart-head">
                <h3>Drinking classifier</h3>
              </div>
              <div class="model-metrics">
                <div>
                  <p class="metric-label">Baseline accuracy</p>
                  <strong>{(siteData.notebookBaseline.drinking.accuracy * 100).toFixed(1)}%</strong>
                </div>
                <div>
                  <p class="metric-label">Current accuracy</p>
                  <strong>{(latestDrinking.accuracy * 100).toFixed(1)}%</strong>
                  <small>
                    {metricDelta(
                      latestDrinking.accuracy,
                      siteData.notebookBaseline.drinking.accuracy,
                    )}
                  </small>
                </div>
                <div>
                  <p class="metric-label">Baseline F1</p>
                  <strong>{siteData.notebookBaseline.drinking.f1.toFixed(3)}</strong>
                </div>
                <div>
                  <p class="metric-label">Current F1</p>
                  <strong>{latestDrinking.f1.toFixed(3)}</strong>
                  <small>
                    {metricDelta(latestDrinking.f1, siteData.notebookBaseline.drinking.f1)}
                  </small>
                </div>
              </div>
            </article>
          </div>

          <div class="chart-grid two-up">
            <FeatureImportanceBars
              title="Smoking model feature importance"
              rows={siteData.models.smokingFeatureImportance}
            />
            <FeatureImportanceBars
              title="Drinking model feature importance"
              rows={siteData.models.drinkingFeatureImportance}
            />
          </div>

          <div class="chart-grid two-up">
            <ConfusionMatrix
              title="Smoking confusion matrix"
              labels={siteData.models.smokingConfusionMatrix.labels}
              matrix={siteData.models.smokingConfusionMatrix.matrix}
              labelMap={smokingLabelMap}
            />
            <ConfusionMatrix
              title="Drinking confusion matrix"
              labels={siteData.models.drinkingConfusionMatrix.labels}
              matrix={siteData.models.drinkingConfusionMatrix.matrix}
              labelMap={drinkingLabelMap}
            />
          </div>

          <article class="notes-card">
            <h3>How to interpret the model results</h3>
            <ul class="note-list">
              {modelContextNotes.map((note) => <li>{note}</li>)}
            </ul>
          </article>
        </section>

        <section id="dashboard" class="section">
          <SectionHeading
            kicker="Dashboard"
            title="Interactive dashboard and performance snapshot"
            intro="Use the embedded report to explore multiple views of the project without leaving the site."
          />

          <DashboardEmbed />

          <div class="metric-grid">
            <MetricCard
              label="Smoking accuracy"
              value={`${(latestSmoking.accuracy * 100).toFixed(1)}%`}
              note="current monitored model"
            />
            <MetricCard
              label="Drinking accuracy"
              value={`${(latestDrinking.accuracy * 100).toFixed(1)}%`}
              note="current monitored model"
            />
            <MetricCard
              label="Refresh cadence"
              value={formatSchedule(siteData.project.schedulerJobs[0]?.schedule)}
              note={siteData.project.schedulerJobs[0]?.state ?? "ENABLED"}
            />
            <MetricCard
              label="Tracked models"
              value={String(siteData.cloudPipeline.promotions.length)}
              note="current monitoring entries"
            />
          </div>

          <article class="notes-card">
            <h3>Ways to use the dashboard</h3>
            <ul class="note-list">
              {dashboardNotes.map((note) => <li>{note}</li>)}
            </ul>
          </article>
        </section>

        <section id="playground" class="section">
          <SectionHeading
            kicker="Prediction Explorer"
            title="Compare individual profiles"
            intro="Use the sample population for a quick side-by-side view, with an expanded profile form available in the full live experience."
          />

          <ModelPlayground defaults={siteData.models.playgroundDefaults} />
        </section>

        <section id="references" class="section">
          <SectionHeading
            kicker="References"
            title="Research and source material"
            intro="Selected research and source material that support the patterns and modeling choices presented throughout the site."
          />

          <div class="references-list">
            {references.map((reference) => <p>{reference}</p>)}
          </div>
        </section>
      </div>
    </div>
  </main>

  <footer class="site-footer">
    <p>
      Smoking and Drinking Prediction: an interactive view of health patterns, predictive signals,
      and dashboard reporting.
    </p>
    <p>Snapshot generated on {new Date(siteData.generatedAt).toLocaleString()}.</p>
  </footer>
</BaseLayout>
